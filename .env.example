# RepoSense Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub Personal Access Token
# Required for accessing GitHub API and fetching repository data
# 
# How to get:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token (classic)"
# 3. Select scopes:
#    - For public repos only: select "public_repo"
#    - For private repos: select "repo" (full control)
# 4. Generate token and copy it here
#
# Rate limits:
# - Without token: 60 requests/hour
# - With token: 5,000 requests/hour
#
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ============================================================================
# GROQ AI CONFIGURATION
# ============================================================================

# Groq API Key
# Required for all AI-powered features (analysis, chat, etc.)
#
# How to get:
# 1. Sign up at https://console.groq.com
# 2. Navigate to API Keys section
# 3. Generate new API key
# 4. Copy the key here
#
# Note: Keep this secret! Anyone with this key can use your Groq credits
#
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq Model
# The model to use for AI analysis
#
# Options:
# - mixtral-8x7b-32768 (recommended, fast and accurate)
# - llama2-70b-4096
# - gemma-7b-it
#
# Default: mixtral-8x7b-32768
#
GROQ_MODEL=mixtral-8x7b-32768

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================

# Firebase Service Account Credentials Path
# Path to your Firebase service account JSON file
#
# How to get:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project (or create new one)
# 3. Go to Project Settings → Service Accounts
# 4. Click "Generate New Private Key"
# 5. Save the JSON file securely
# 6. Update the path below
#
# Security: 
# - Never commit this JSON file to git
# - Add it to .gitignore (already done)
# - Use absolute path or relative to backend directory
#
# Example paths:
# - Relative: ./firebase-credentials.json
# - Absolute: /path/to/firebase-credentials.json
# - Windows: C:/path/to/firebase-credentials.json
#
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ============================================================================
# OPTIONAL CONFIGURATION
# ============================================================================

# Application Environment
# Options: development, staging, production
# Default: development
#
# APP_ENV=development

# API Port
# Port for FastAPI backend server
# Default: 8000
#
# API_PORT=8000

# CORS Origins
# Comma-separated list of allowed origins for CORS
# Default: http://localhost:5173,http://localhost:3000
#
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
#
# LOG_LEVEL=INFO

# Maximum Repository Size (MB)
# Repositories larger than this will be rejected
# Default: 100
#
# MAX_REPO_SIZE_MB=100

# Maximum Files to Analyze
# Limit number of files to prevent excessive API usage
# Default: 150
#
# MAX_FILES=150

# Bob API Timeout (seconds)
# Timeout for Bob API requests
# Default: 120
#
# BOB_API_TIMEOUT=120

# Cache TTL (seconds)
# Time-to-live for cached analysis results
# Default: 86400 (24 hours)
#
# CACHE_TTL=86400

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Debug Mode
# Enable detailed error messages and logging
# WARNING: Never enable in production!
# Default: False
#
# DEBUG=False

# Reload on Code Changes
# Auto-reload server when code changes (uvicorn --reload)
# Only for development
# Default: True in development
#
# AUTO_RELOAD=True

# ============================================================================
# NOTES
# ============================================================================

# 1. All values are case-sensitive
# 2. No quotes needed around values
# 3. No spaces around = sign
# 4. Comments start with #
# 5. Empty lines are ignored
# 6. This file should be copied to .env and customized
# 7. Never commit .env to version control
# 8. Keep your credentials secure and private

# ============================================================================
# SECURITY CHECKLIST
# ============================================================================

# ✅ .env file is in .gitignore
# ✅ Firebase credentials JSON is in .gitignore
# ✅ API keys are kept secret
# ✅ No credentials in code or commits
# ✅ Different credentials for dev/staging/prod
# ✅ Regular key rotation policy
# ✅ Limited API key permissions
# ✅ Monitoring for unusual API usage

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# Issue: "GitHub API rate limit exceeded"
# Solution: Add GITHUB_TOKEN with proper permissions

# Issue: "Bob API authentication failed"
# Solution: Verify BOB_API_KEY is correct and active

# Issue: "Firebase permission denied"
# Solution: Check FIREBASE_CREDENTIALS_PATH and file permissions

# Issue: "Module not found" errors
# Solution: Ensure all dependencies are installed (pip install -r requirements.txt)

# For more help, see SETUP.md or open an issue on GitHub